# Driftpilot environment variables (handoff doc §14).
# Values live in Vercel project settings (encrypted) — never committed.
# Anything without NEXT_PUBLIC_ is server-only and must never appear in a
# client component.

# ── Phase 1 ──────────────────────────────────────────────────────────────
# Canonical site origin (no trailing slash). REQUIRED in production — build
# throws if unset when NODE_ENV=production. Dev falls back to https://driftpilot.ca.
NEXT_PUBLIC_SITE_URL=

# Contact form → CRM webhook (HubSpot/Pipedrive)
CRM_WEBHOOK_URL=

# Early access form → separate automotive list (funnel isolation)
AUTOMOTIVE_WEBHOOK_URL=

# Analytics — Vercel Analytics (@vercel/analytics in src/app/layout.tsx).
# Zero-config on Vercel: no env vars needed. Do not add a second tracking
# system without pruning this one — perf budget assumes a single provider.

# ── Phase 2 — Headless WordPress ─────────────────────────────────────────
# WPGraphQL endpoint, e.g. https://cms.driftpilot.ca/graphql
WPGRAPHQL_ENDPOINT=
WPGRAPHQL_AUTH_TOKEN=
# Verifies WP publish webhook → /api/revalidate
REVALIDATE_SECRET=

# ── Phase 3 — AWS lead pipeline ──────────────────────────────────────────
LEADS_QUEUE_URL=
